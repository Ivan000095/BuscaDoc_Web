models:
    Doctor: { tableName: doctores, user_id: 'id foreign:users.id', cedula: 'string nullable', idiomas: 'string nullable', descripcion: 'text nullable', costo: 'decimal:8,2', horario_entrada: 'time nullable', horario_salida: 'time nullable', relationships: { belongsTo: User } }
    User: { name: string, email: 'string unique', password: string, role: 'enum:admin,doctor,paciente,farmacia', foto: 'string nullable', f_nacimiento: 'date nullable', genero: 'string nullable', latitud: 'decimal:10,8 nullable', longitud: 'decimal:11,8 nullable', estado: 'boolean default:true', relationships: { hasOne: 'Doctor, Paciente, Farmacia', hasMany: 'Mensaje, Comentario, Cita' } }
    Especialidad: { tableName: especialidades, nombre: string }
    Paciente: { user_id: 'id foreign:users.id', tipo_sangre: 'string nullable', alergias: 'text nullable', relationships: { belongsTo: User, hasMany: Cita } }
    Farmacia: { tableName: farmacias, user_id: 'id foreign:users.id', nom_farmacia: string, rfc: 'string nullable', telefono: 'string nullable', descripcion: 'text nullable', horario: 'string nullable', dias_op: 'string nullable', relationships: { belongsTo: User } }
    Comentario: { id_autor: 'id foreign:users.id', id_destinatario: 'id foreign:users.id', tipo: 'enum:resena,pregunta', calificacion: 'integer nullable', contenido: 'text nullable', relationships: { belongsTo: User, hasMany: Respuesta } }
    Respuesta: { comentario_id: 'id foreign:comentarios.id', id_respondedor: 'id foreign:users.id', contenido: text, relationships: { belongsTo: 'Comentario, User' } }
    Mensaje: { id_remitente: 'id foreign:users.id', id_destinatario: 'id foreign:users.id', contenido: text, leido: 'boolean default:false', relationships: { belongsTo: User } }
    Cita: { doctor_id: 'id foreign:doctors.id', paciente_id: 'id foreign:pacientes.id', fecha_hora: datetime, detalles: 'text nullable', estado: 'enum:pendiente,confirmada,cancelada,completada', relationships: { belongsTo: User } }
    Reporte: { id_usr_reporte: 'id foreign:users.id', id_usr_reportado: 'id foreign:users.id', razon: text, relationships: { belongsTo: User } }
    Doctor_Especialidad: { tableName: doctor_especialidad, doctor_id: 'id foreign:doctors.id', especialidad_id: 'id foreign:especialidads.id' }
